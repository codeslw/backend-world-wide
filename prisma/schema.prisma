generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  role          Role           @default(CLIENT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  adminChats    Chat[]         @relation("AdminChats")
  clientChats   Chat[]         @relation("ClientChats")
  messages      Message[]
  profile       Profile?
  refreshTokens RefreshToken[]
  partnerStudents    PartnerStudent[]    @relation("PartnerStudents")
  partnerApplications PartnerApplication[] @relation("PartnerApplications")
  // readMessages Message[] @relation("MessageReads")
  partnerOrganization PartnerOrganization? @relation("OrgOwner")
  partnerMembership   PartnerMember?       @relation("MemberOf")
  auditLogs           PartnerAuditLog[]    @relation("AuditActor")

  @@map("users")
}

model Program {
  id                 String              @id @default(uuid())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  parentId           String?
  descriptionEn      String?
  descriptionRu      String?
  descriptionUz      String?
  title              String
  parent             Program?            @relation("ProgramToProgram", fields: [parentId], references: [id])
  children           Program[]           @relation("ProgramToProgram")
  universityPrograms     UniversityProgram[]
  applications           Application[]
  partnerApplications    PartnerApplication[]
  processTemplate        ApplicationProcessTemplate?

  @@map("programs")
}

model Country {
  code     Int     @id
  nameUz   String
  nameRu   String
  nameEn   String
  isMain   Boolean @default(false)
  photoUrl String?

  // General Info
  overviewEn String?
  overviewRu String?
  overviewUz String?
  images     String[] @default([])

  // Financial Requirements
  proofOfFundsAmount      String?
  tuitionMin              Float?
  tuitionMax              Float?
  tuitionCurrency         String?
  costOfLivingMin         Float?
  costOfLivingMax         Float?
  costOfLivingCurrency    String?
  scholarshipAvailability String?

  // Visa & Immigration
  visaAcceptanceRate       String?
  visaProcessingTime       String?
  visaInterviewRequired    Boolean  @default(false)
  dependentVisaAvailable   Boolean  @default(false)
  visaFee                  Float?
  visaFeeCurrency          String?
  isVisaFeeRefundable      Boolean  @default(false)
  insuranceFee             Float?
  insuranceFeeCurrency     String?
  isInsuranceFeeRefundable Boolean  @default(false)
  bankStatement            Float?
  otherExpenses            String[] @default([])
  visaRequiredDocuments    String?  @db.Text

  // Work Rights
  workingDuringStudiesAllowed Boolean  @default(false)
  workingHoursBachelor        String?
  workingHoursMaster          String?
  workingPlacesAllowed        String[] @default([])
  partTimeWorkHours           String?
  postStudyWorkDuration       String?
  prPathwayAvailable          Boolean  @default(false)

  // Academic & Logistical
  majorIntakes              String[] @default([])
  applicationTimeline       String?
  acceptedLanguageTests     String[] @default([])
  standardizedTestsRequired String?
  gapAcceptance             String?

  // Life & Experience
  accommodationTypes             String[] @default([])
  averageRentMin                 Float?
  averageRentMax                 Float?
  rentCurrency                   String?
  safetyIndex                    String?
  healthcareDetails              String?
  internationalStudentPopulation String?
  hasHalalFood                   Boolean  @default(false)
  hasVegetarianFood              Boolean  @default(false)
  isVisaRequired                 Boolean  @default(true)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  cities       City[]
  universities University[]
}

model City {
  id            String       @id @default(uuid())
  nameUz        String
  nameRu        String
  nameEn        String
  descriptionUz String?
  descriptionRu String?
  descriptionEn String?
  countryCode   Int
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  country       Country      @relation(fields: [countryCode], references: [code])
  universities  University[]
}

model University {
  id                      String                  @id @default(uuid())
  established             Int?
  type                    String
  descriptionUz           String?
  descriptionRu           String?
  descriptionEn           String?
  website                 String?
  email                   String?
  phone                   String?
  address                 String
  winterIntakeDeadline    DateTime?
  autumnIntakeDeadline    DateTime?
  ranking                 Int?
  studentsCount           Int?
  acceptanceRate          Float?
  avgApplicationFee       Float?
  applicationFeeCurrency  String?
  photoUrl                String?
  logoUrl                 String?
  additionalPhotoUrls     String[]                @default([])
  youtubeVideoUrl         String?
  isMain                  Boolean                 @default(false)
  cityId                  String
  countryCode             Int
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  name                    String
  city                    City                    @relation(fields: [cityId], references: [id])
  country                 Country                 @relation(fields: [countryCode], references: [code])
  universityPrograms      UniversityProgram[]
  applications            Application[]
  hasScholarship          Boolean                 @default(false)
  hasFullScholarship      Boolean                 @default(false)
  additionalExpenses      Json                    @default("[]")
  scholarshipRequirements String[]                @default([])
  scholarships            Scholarship[]
  admissionRequirements   AdmissionRequirement[]
  campuses                Campus[]
  partnerApplications     PartnerApplication[]
  isAdmissionFeeRefundable Boolean                 @default(false)
  agencyServiceId         String?
  agencyService           AgencyService?          @relation(fields: [agencyServiceId], references: [id])

  @@index([name])
  @@index([type])
  @@index([ranking])
  @@index([established])
  @@index([countryCode])
  @@index([cityId])
  @@index([isMain])
  @@map("universities")
}

model AgencyService {
  id     String @id @default(uuid())
  nameEn String
  nameRu String
  nameUz String

  // Unified tariffs field storing an array of tariff objects
  // Each tariff object structure:
  // { 
  //   titleEn: string, titleRu: string, titleUz: string, 
  //   price: number, currency: string, 
  //   servicesEn: string[], servicesRu: string[], servicesUz: string[],
  //   notesEn: string[], notesRu: string[], notesUz: string[],
  //   discountPercentage?: number,
  //   discountDeadline?: Date
  // }
  tariffs Json? @default("[]")

  universities University[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agency_services")
}

model UniversityProgram {
  id                 String     @id @default(uuid())
  universityId       String
  programId          String
  tuitionFee         Float
  tuitionFeeType     String     @default("tuition_per_year")
  tuitionFeeCurrency String     @default("USD")
  studyLevel         StudyLevel @default(BACHELOR)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  duration           Float?
  scholarshipAppliedTutionFee Float?

  studyLanguageId String?
  studyLanguage   StudyLanguage? @relation(fields: [studyLanguageId], references: [id])
  program       Program                   @relation(fields: [programId], references: [id])
  university    University                @relation(fields: [universityId], references: [id], onDelete: Cascade)
  scholarships  Scholarship[]
  intakes       UniversityProgramIntake[]
  campuses      Campus[]

  @@unique([universityId, programId, studyLevel])
  @@index([universityId])
  @@index([programId])
  @@index([tuitionFee])
  @@index([studyLevel])
  @@index([studyLanguageId])
  @@map("university_programs")
}

model StudyLanguage {
  id     String @id @default(uuid())
  nameEn String
  nameRu String
  nameUz String

  universityPrograms UniversityProgram[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("study_languages")
}

model SiteSetting {
  id        String   @id @default("global")
  appTitle  String
  logoUrl   String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@map("site_settings")
}


model Intake {
  id                 String                    @id @default(uuid())
  month              String
  year               Int
  deadline           DateTime
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  universityPrograms UniversityProgramIntake[]

  @@map("intakes")
}

model UniversityProgramIntake {
  id                  String            @id @default(uuid())
  universityProgramId String
  intakeId            String
  universityProgram   UniversityProgram @relation(fields: [universityProgramId], references: [id], onDelete: Cascade)
  intake              Intake            @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())

  @@unique([universityProgramId, intakeId])
  @@index([universityProgramId])
  @@index([intakeId])
  @@map("university_program_intakes")
}

model File {
  id        String   @id @default(uuid())
  filename  String
  url       String
  createdAt DateTime @default(now())
}

model Chat {
  id                   String     @id @default(uuid())
  clientId             String
  adminId              String?
  partnerApplicationId String?
  status               ChatStatus @default(ACTIVE)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  admin                User?               @relation("AdminChats", fields: [adminId], references: [id])
  client               User                @relation("ClientChats", fields: [clientId], references: [id])
  messages             Message[]
  partnerApplication   PartnerApplication? @relation(fields: [partnerApplicationId], references: [id])

  @@index([clientId])
  @@index([adminId])
  @@index([status])
  @@index([partnerApplicationId])
}

model Message {
  id           String        @id @default(uuid())
  chatId       String
  senderId     String
  text         String?
  fileUrl      String?
  replyToId    String?
  readByClient Boolean       @default(false)
  readByAdmin  Boolean       @default(false)
  isEdited     Boolean       @default(false)
  editedAt     DateTime?
  status       MessageStatus @default(SENT)
  createdAt    DateTime      @default(now())
  chat         Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  replyTo      Message?      @relation("Replies", fields: [replyToId], references: [id])
  replies      Message[]     @relation("Replies")
  sender       User          @relation(fields: [senderId], references: [id])
  // readBy    User[]    @relation("MessageReads")

  @@index([chatId])
  @@index([senderId])
  @@index([replyToId])
  @@index([chatId, createdAt])
  @@index([chatId, readByClient])
  @@index([chatId, readByAdmin])
}

model Profile {
  id                        String                @id @default(uuid())
  firstName                 String?
  lastName                  String?
  passportSeriesAndNumber   String?
  email                     String?
  phoneNumber               String?
  userId                    String                @unique
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  address                   String?
  dateOfBirth               DateTime?
  gender                    Gender?
  middleName                String?
  nationality               String?
  passportCopyGuid          String?
  passportExpiryDate        DateTime?
  cvGuid                    String?
  motivationLetterGuid      String?
  recommendationLetterGuids String[]              @default([])
  applications              Application[]
  user                      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  educationHistory          Education[]
  languageCertificates      LanguageCertificate[]
  standardizedTests         StandardizedTest[]

  @@index([createdAt])
  @@map("profiles")
}

model StandardizedTest {
  id              String               @id @default(uuid())
  profileId       String
  profile         Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  testType        StandardizedTestType
  score           Int
  certificateGuid String?
  dateOfIssue     DateTime
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([profileId])
  @@map("standardized_tests")
}

model Education {
  id             String     @id @default(uuid())
  profileId      String
  profile        Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  degree         DegreeType
  institution    String
  graduationYear Int
  gpa            Float?
  transcriptGuid String?
  diplomaGuid    String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([profileId])
  @@map("education_history")
}

model LanguageCertificate {
  id              String       @id @default(uuid())
  profileId       String
  profile         Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  testType        LanguageTest
  score           Float
  certificateGuid String?
  dateOfIssue     DateTime
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([profileId])
  @@map("language_certificates")
}

model Application {
  id                  String            @id @default(uuid())
  profileId           String
  preferredCountry    String
  preferredUniversity String
  preferredProgram    String
  intakeSeason        IntakeSeason
  intakeYear          Int
  applicationStatus   ApplicationStatus @default(DRAFT)
  rejectionReason     String?
  submittedAt         DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  profile             Profile           @relation(fields: [profileId], references: [id])
  program             Program           @relation(fields: [preferredProgram], references: [id])
  university          University        @relation(fields: [preferredUniversity], references: [id])

  @@index([profileId])
  @@index([applicationStatus])
  @@index([profileId, applicationStatus])
  @@index([preferredUniversity])
  @@index([preferredProgram])
  @@index([createdAt])
  @@map("applications")
}

model MiniApplication {
  id          String                @id @default(uuid())
  firstName   String
  lastName    String
  phoneNumber String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  status      MiniApplicationStatus @default(NEW)

  @@index([status])
  @@map("mini_applications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Scholarship {
  id    String @id @default(uuid())
  title String

  // Amount as string to support ranges and percentages (e.g. "£1,000 - £2,500 GBP" or "15%")
  amount String

  // Auto-application flag
  isAutoApplied Boolean @default(false)

  // Full scholarship flag (100% tuition covered)
  isFullScholarship Boolean @default(false)

  // Visibility flag — controls whether scholarship appears in public listing
  isVisible Boolean @default(true)

  // Eligibility arrays
  nationalities String[] @default([])
  programLevels String[] @default([])

  // Rich text content fields
  overview            String  @db.Text
  howItWorks          String? @db.Text
  scholarshipValue    String? @db.Text
  importantNotes      String? @db.Text
  eligibilityCriteria String  @db.Text

  // Optional source URL
  sourceUrl String?

  // YouTube video URL for preview
  videoUrl String?

  // Timestamps
  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())

  // Relations
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  programs UniversityProgram[]

  @@index([universityId])
  @@map("scholarships")
}

enum ScholarshipType {
  MERIT
  ENTRANCE
  ATHLETIC
  COMMUNITY
  OTHER
}

enum Role {
  ADMIN
  CLIENT
  PARTNER
}

enum PartnerRole {
  OWNER
  MANAGER
  MEMBER
}

enum PartnerAction {
  VIEW_STUDENTS
  ADD_STUDENT
  EDIT_STUDENT
  DELETE_STUDENT
  UPLOAD_DOCUMENTS
  DELETE_DOCUMENTS
  VIEW_APPLICATIONS
  CREATE_APPLICATION
  VIEW_APPLICATION_DETAIL
  INVITE_MEMBERS
  REMOVE_MEMBERS
  EDIT_MEMBER_PERMISSIONS
}

model PartnerOrganization {
  id                 String          @id @default(uuid())
  ownerId            String          @unique
  owner              User            @relation("OrgOwner", fields: [ownerId], references: [id])
  members            PartnerMember[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  name               String?
  isActive           Boolean         @default(true)
  logoUrl            String?
  website            String?
  phone              String?
  email              String?
  description        String?
  registrationNumber String?
  country            String?
  city               String?
  address            String?
  linkedinUrl                 String?
  instagramUrl                String?
  facebookUrl                 String?
  registrationCertificateUrl  String?
  auditLogs                   PartnerAuditLog[]

  @@map("partner_organizations")
}

model PartnerMember {
  id             String              @id @default(uuid())
  organizationId String
  organization   PartnerOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String              @unique
  user           User                @relation("MemberOf", fields: [userId], references: [id], onDelete: Cascade)
  role           PartnerRole         @default(MEMBER)
  permissions    PartnerPermission[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@map("partner_members")
  @@index([organizationId])
}

model PartnerPermission {
  id       String        @id @default(uuid())
  memberId String
  member   PartnerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  action   PartnerAction
  granted  Boolean       @default(false)

  @@unique([memberId, action])
  @@map("partner_permissions")
  @@index([memberId])
}

enum PartnerAuditAction {
  // Auth
  LOGIN
  // Students
  STUDENT_CREATED
  STUDENT_UPDATED
  STUDENT_DELETED
  // Documents
  DOCUMENT_UPLOADED
  DOCUMENT_DELETED
  // Applications
  APPLICATION_CREATED
  APPLICATION_UPDATED
  APPLICATION_DELETED
  APPLICATION_STATUS_CHANGED
  // Team / members
  MEMBER_INVITED
  MEMBER_REMOVED
  MEMBER_PERMISSIONS_UPDATED
  // Company profile
  COMPANY_UPDATED
  // Admin-initiated
  ACCESS_ENABLED
  ACCESS_DISABLED
}

/// Immutable activity trail of partner actions. `actorId` is the partner User
/// who performed the action (or the admin, for admin-initiated entries such as
/// access toggles). `organizationId` denormalizes the partner org so the admin
/// can filter a single partner's whole history cheaply.
model PartnerAuditLog {
  id             String              @id @default(uuid())
  createdAt      DateTime            @default(now())

  action         PartnerAuditAction
  actorId        String?
  actor          User?               @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole      Role?
  actorName      String? // snapshot of the actor's display name at action time
  organizationId String?
  organization   PartnerOrganization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // What the action targeted (entity kind + id + human label)
  targetType     String? // e.g. "PartnerStudent", "PartnerApplication", "PartnerMember"
  targetId       String?
  targetLabel    String? // e.g. student full name, application id, member email

  // Free-form structured context (before/after, status transition, ip, etc.)
  metadata       Json?
  ipAddress      String?

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
  @@index([createdAt])
  @@map("partner_audit_logs")
}

enum UniversityType {
  PUBLIC
  PRIVATE
}

enum ChatStatus {
  ACTIVE
  CLOSED
  PENDING
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum IntakeSeason {
  FALL
  SPRING
  SUMMER
  WINTER
}

enum LanguageTest {
  IELTS
  TOEFL
  DUOLINGO
  NONE
}

enum DegreeType {
  HIGH_SCHOOL
  BACHELOR
  MASTER
  PHD
}

enum StandardizedTestType {
  GMAT
  CAT
  GRE
}

enum Gender {
  MALE
  FEMALE
}

enum MiniApplicationStatus {
  NEW
  CONTACTED
  CLOSED
}

enum MessageStatus {
  SENDING
  SENT
  DELIVERED
  READ
}

enum StudyLevel {
  BACHELOR
  MASTER
  PHD
  LANGUAGE_COURSE
  FOUNDATION
}

model AdmissionRequirement {
  id                   String     @id @default(uuid())
  universityId         String
  university           University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  programLevel         StudyLevel
  minEducationLevel    String
  minGpa               String
  languageRequirements Json
  notes                String[]
  entryRequirements    String     @db.Text
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@unique([universityId, programLevel])
  @@map("admission_requirements")
}

model Campus {
  id           String     @id @default(uuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)

  // Core Identification
  photos          String[]  @default([])
  name            String
  code            String?
  establishedDate DateTime?

  // Location & Geospatial Data
  address    String
  latitude   Float?
  longitude  Float?
  boundaries Json? // GeoJSON or polygon coordinates
  timezone   String?

  // Physical Infrastructure
  totalArea       Float? // in square meters
  buildingCount   Int?
  facilityTypes   String[] @default([]) // string boolean/list indicating amenities
  parkingCapacity Int?

  // Administrative & Operational
  director       String?
  email          String?
  phone          String?
  operatingHours String?
  status         CampusStatus @default(ACTIVE)

  // YouTube video URL for preview
  videoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  universityPrograms UniversityProgram[]

  @@index([universityId])
  @@map("campuses")
}

enum CampusStatus {
  ACTIVE
  UNDER_CONSTRUCTION
  CLOSED
}

enum PartnerApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  DOCUMENTS_REQUIRED
  CONDITIONAL_OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
  ENROLLED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  OTHER
}

// ── Application Process Templates ──────────────────────────────────────────────

model ApplicationProcessTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean  @default(false) // true = standard template used as fallback
  programId   String?  @unique         // null = standard template; non-null = program-specific override
  program     Program? @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps ApplicationProcessStep[]

  @@index([isDefault])
  @@map("application_process_templates")
}

model ApplicationProcessStep {
  id          String  @id @default(uuid())
  templateId  String
  template    ApplicationProcessTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order       Int
  name        String
  description String?
  statusKey   String  // maps to PartnerApplicationStatus value
  isActive    Boolean @default(true)

  requiredDocuments ApplicationDocumentType[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@map("application_process_steps")
}

model ApplicationDocumentType {
  id          String @id @default(uuid())
  stepId      String
  step        ApplicationProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  name        String
  description String?
  required    Boolean  @default(true)
  fileTypes   String[] @default(["pdf"])
  maxSizeMb   Int      @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stepId])
  @@map("application_document_types")
}

// ── Partner Applications ──────────────────────────────────────────────────────

model PartnerApplication {
  id               String                 @id @default(uuid())
  partnerId        String                 // the partner (User) who submitted
  partner          User                   @relation("PartnerApplications", fields: [partnerId], references: [id], onDelete: Cascade)
  partnerStudentId String
  partnerStudent   PartnerStudent         @relation(fields: [partnerStudentId], references: [id], onDelete: Cascade)
  universityId     String
  university       University             @relation(fields: [universityId], references: [id])
  programId        String
  program          Program                @relation(fields: [programId], references: [id])
  intakeSeason     IntakeSeason
  intakeYear       Int

  status           PartnerApplicationStatus @default(DRAFT)
  rejectionReason  String?
  submittedAt      DateTime?
  reviewedAt       DateTime?

  // Qualifications snapshot
  englishProficiency String?
  gpa                String?
  prerequisites      String?
  notes              String?
  adminNotes         String?
  assignedTo         String?

  // Backup / alternative programs (JSON array of { programId, universityId, programTitle, universityName })
  backupPrograms     Json?    @default("[]")

  // Documents uploaded by partner (JSON array of { documentTypeId, fileName, fileUrl, uploadedAt })
  documents          Json?    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partnerId])
  @@index([partnerStudentId])
  @@index([status])
  @@index([universityId])
  @@index([programId])
  chats              Chat[]

  @@index([createdAt])
  @@map("partner_applications")
}

model Review {
  id                 String     @id @default(uuid())
  type               ReviewType @default(STUDENT_TESTIMONIAL)
  fullName           String
  phoneNumber        String?
  rating             Int        @default(5)
  content            String?
  videoUrl           String?
  imageUrl           String?
  country            String?
  destinationCountry String?
  degree             String?
  university         String?
  ranking            String?
  scholarshipAmount  String?
  sortOrder          Int        @default(0)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([type])
  @@index([sortOrder])
  @@index([rating])
  @@index([createdAt])
  @@map("reviews")
}

enum ReviewType {
  STUDENT_SUCCESS_VISA
  STUDENT_TESTIMONIAL
  UNIVERSITY_OFFER
}

model PartnerStudent {
  id                   String        @id @default(uuid())
  partnerId            String
  partner              User          @relation("PartnerStudents", fields: [partnerId], references: [id], onDelete: Cascade)

  // 1.1 Personal Information
  firstName            String
  lastName             String
  middleName           String?
  fatherFullName       String?
  motherFullName       String?
  dateOfBirth          DateTime?
  firstLanguage        String?
  countryOfCitizenship String?
  passportNumber       String?
  passportPlaceOfBirth String?
  passportExpiryDate   DateTime?
  maritalStatus        MaritalStatus?
  gender               Gender?
  email                String?
  phone                String?

  // 1.2 Address
  streetAddress        String?
  city                 String?
  country              String?
  provinceState        String?
  postalZipCode        String?

  // 2.1 Education details
  countryOfEducation      String?
  highestLevelOfEducation String?
  previousEducationLevel  String?
  desiredEducationLevel   String?
  gradingScheme           String?
  gradeScaleOutOf         String?
  gradeAverage            String?
  graduated               Boolean?
  schools                 Json?

  // 3.1 & 3.2 Certificates & Test Scores
  certificates         Json?
  testScores           Json?

  // 4. Additional details
  leadSource           String?
  studentAgent         String?
  studentStage         String?
  emergencyName        String?
  emergencyPhone       String?
  emergencyRelation    String?
  financialSupport     String?
  howHeard             String?
  additionalNotes      String?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  partnerApplications  PartnerApplication[]
  studentDocuments     StudentDocument[]

  @@index([partnerId])
  @@map("partner_students")
}

model StudentDocument {
  id        String         @id @default(uuid())
  studentId String
  student   PartnerStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type      String
  name      String
  url       String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([studentId])
  @@map("student_documents")
}

// ─── About page CMS ──────────────────────────────────────────────────────────
// Admin-managed "Our Story" content. Singleton page + ordered lists.
// All localized text stored as Uz/Ru/En triplets; images stored as DO Spaces
// key and resolved to a public URL on read.

// Singleton: there is a single row holding the page-level narrative copy.
model AboutPage {
  id String @id @default(uuid())

  // Dark hero
  heroTitleUz    String?
  heroTitleRu    String?
  heroTitleEn    String?
  heroSubtitleUz String?
  heroSubtitleRu String?
  heroSubtitleEn String?
  heroImageUrl   String?

  // Intro / "who we are"
  introHeadingUz String?
  introHeadingRu String?
  introHeadingEn String?
  introBodyUz    String?
  introBodyRu    String?
  introBodyEn    String?

  // Operator statement: "TalabaLink is developed & operated by Worldwide Consulting"
  operatorStatementUz String?
  operatorStatementRu String?
  operatorStatementEn String?

  // History highlights surfaced as headline stats
  foundedYear   Int?    @default(2020)
  platformLaunch String? @default("2026-01")

  // Section headings (so the whole page is editable, not just data)
  founderHeadingUz     String?
  founderHeadingRu     String?
  founderHeadingEn     String?
  milestonesHeadingUz  String?
  milestonesHeadingRu  String?
  milestonesHeadingEn  String?
  teamHeadingUz        String?
  teamHeadingRu        String?
  teamHeadingEn        String?
  certificatesHeadingUz String?
  certificatesHeadingRu String?
  certificatesHeadingEn String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("about_page")
}

model Founder {
  id       String  @id @default(uuid())
  name     String
  roleUz   String?
  roleRu   String?
  roleEn   String?
  bioUz    String?
  bioRu    String?
  bioEn    String?
  photoUrl String?
  // optional contact / social
  linkedinUrl String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("about_founders")
}

model Milestone {
  id            String  @id @default(uuid())
  // Free-form label so "2020", "Jan 2026", "Q1 2024" all work
  year          String
  titleUz       String?
  titleRu       String?
  titleEn       String?
  descriptionUz String?
  descriptionRu String?
  descriptionEn String?
  sortOrder     Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("about_milestones")
}

model TeamMember {
  id         String  @id @default(uuid())
  name       String
  positionUz String?
  positionRu String?
  positionEn String?
  // role/title shown under the position (e.g. responsibilities tagline)
  roleUz     String?
  roleRu     String?
  roleEn     String?
  // optional department/group label for grouping in the grid
  groupUz    String?
  groupRu    String?
  groupEn    String?
  photoUrl   String?
  linkedinUrl String?
  sortOrder  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("about_team_members")
}

model Certificate {
  id        String  @id @default(uuid())
  titleUz   String?
  titleRu   String?
  titleEn   String?
  issuerUz  String?
  issuerRu  String?
  issuerEn  String?
  imageUrl  String?
  isFeatured Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isFeatured])
  @@index([sortOrder])
  @@map("about_certificates")
}
