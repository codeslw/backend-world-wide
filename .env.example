# Database (connection_limit controls Prisma connection pool size)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?connection_limit=20&pool_timeout=10"

# JWT Configuration
JWT_SECRET="your-access-token-secret-key"
JWT_REFRESH_SECRET="your-refresh-token-secret-key"  # Optional: Use different secret for refresh tokens
JWT_ACCESS_EXPIRATION="15m"   # Access token expiration (15 minutes recommended)
JWT_REFRESH_EXPIRATION="7d"   # Refresh token expiration (7 days recommended)

# Swagger Documentation
SWAGGER_USER="Saidkamol"
SWAGGER_PASSWORD="your-secure-password"

# Logging
# LOG_LEVEL accepts: error, warn, info/log, debug, verbose/trace
LOG_LEVEL="debug"
# LOG_FORMAT accepts: pretty, json
LOG_FORMAT="pretty"

# Exchange rates (currency converter)
# Get a free key at https://www.exchangerate-api.com/ (free tier: 1,500 requests/month).
# The backend fetches once per refresh (base USD, all currencies) and caches it in the
# DB; a cron refreshes every 12h but only calls the API once the provider publishes new
# rates, so real usage is ~60 requests/month. Leave EXCHANGE_RATE_API_KEY empty to disable
# the converter (the /currencies/rates endpoint then returns 503 and the UI hides itself).
EXCHANGE_RATE_API_KEY=""

# Other environment variables...
